{
  "name": "numeric-text",
  "version": "0.1.0",
  "description": "SwiftUI-style per-character slide animation for the web",
  "type": "module",
  "main": "./dist/numeric-text.cjs",
  "module": "./dist/numeric-text.js",
  "exports": {
    ".": {
      "import": "./dist/numeric-text.js",
